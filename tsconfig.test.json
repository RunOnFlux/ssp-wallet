{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "esModuleInterop": true,
    "allowJs": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": [
      "node",
      "jest",
      "vite",
      "chrome"
    ],
    "baseUrl": "./",
    "paths": {
      "@storage/*": ["./src/storage/*"],
      "@assets/*": ["./src/assets/*"]
    }
  },
  "include": [
    "src",
    "tests"
  ],
  "exclude": [
    "node_modules",
    "package.json",
    "logs"
  ]
}