{
  "name": "ssp-wallet",
  "description": "Secure. Simple. Powerful.",
  "private": true,
  "version": "1.40.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "postbuild": "node scripts/build-manifests.cjs",
    "build:chrome": "npm run build && node scripts/build-manifests.cjs chrome",
    "build:firefox": "npm run build && node scripts/build-manifests.cjs firefox",
    "build:all": "npm run build && node scripts/build-manifests.cjs",
    "build:deterministic": "bash scripts/deterministic-build.sh",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint ./src ./public",
    "lint:fix": "eslint ./src ./public --fix",
    "type-check": "tsc",
    "preview": "vite preview",
    "postinstall": "patch-package && npm run --workspace=vite-plugin-lavamoat build",
    "generate-policy": "node scripts/generate-lavamoat-policy.js"
  },
  "resolutions": {
    "viem": "2.52.2"
  },
  "overrides": {
    "viem": "2.52.2"
  },
  "dependencies": {
    "@alchemy/aa-core": "3.19.0",
    "@ant-design/icons": "6.2.5",
    "@fontsource/inter": "5.2.8",
    "@metamask/browser-passworder": "6.0.0",
    "@noble/hashes": "2.2.0",
    "@reduxjs/toolkit": "2.12.0",
    "@reown/walletkit": "1.5.5",
    "@runonflux/aa-schnorr-multisig-sdk": "1.3.0",
    "@runonflux/flux-sdk": "1.1.0",
    "@runonflux/solana-multisig": "0.11.0",
    "@runonflux/utxo-lib": "1.0.4",
    "@scure/bip32": "2.2.0",
    "@scure/bip39": "2.2.0",
    "@solana/spl-token": "0.4.14",
    "@solana/web3.js": "1.98.4",
    "@walletconnect/core": "2.23.9",
    "@walletconnect/jsonrpc-utils": "1.0.8",
    "@walletconnect/utils": "2.23.9",
    "antd": "6.4.3",
    "assert": "2.1.0",
    "axios": "1.18.0",
    "bchaddrjs": "0.5.2",
    "bignumber.js": "11.1.3",
    "bs58": "6.0.0",
    "buffer": "6.0.3",
    "crypto-browserify": "3.12.1",
    "currency-symbol-map": "5.1.0",
    "ethers": "6.16.0",
    "events": "3.3.0",
    "export-to-csv": "1.4.0",
    "i18next": "26.3.1",
    "localforage": "1.10.0",
    "lru-cache": "11.5.1",
    "patch-package": "8.0.1",
    "postinstall-postinstall": "2.1.0",
    "process": "0.11.10",
    "react": "19.2.7",
    "react-countdown-circle-timer": "3.2.1",
    "react-dom": "19.2.7",
    "react-i18next": "17.0.8",
    "react-redux": "9.3.0",
    "react-router": "7.17.0",
    "react-secure-storage": "1.3.2",
    "socket.io-client": "4.8.3",
    "stream-browserify": "3.0.0",
    "tweetnacl": "1.0.3",
    "util": "0.12.5",
    "viem": "2.52.2",
    "vite-plugin-lavamoat": "link:packages/vite-plugin-lavamoat"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@lavamoat/allow-scripts": "3.4.3",
    "@types/bchaddrjs": "0.4.3",
    "@types/chrome": "0.1.43",
    "@types/firefox-webext-browser": "143.0.0",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-redux": "7.1.34",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "@vitejs/plugin-react-swc": "4.3.1",
    "@vitest/coverage-v8": "4.1.8",
    "archiver": "8.0.0",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "tsconfig-paths": "4.2.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vite": "7.3.5",
    "vite-plugin-node-polyfills": "0.28.0",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=24"
  },
  "lavamoat": {
    "allowScripts": {
      "$root$": true,
      "@runonflux/aa-schnorr-multisig-sdk>secp256k1": true,
      "@runonflux/flux-sdk>secp256k1": true,
      "@runonflux/utxo-lib>secp256k1": true,
      "@vitejs/plugin-react-swc>@swc/core": true,
      "postinstall-postinstall": true,
      "tsx>esbuild": true
    }
  }
}
